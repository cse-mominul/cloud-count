# Environment Variables for Sohel Gadgets Application
# Copy this file to .env and update the values

# Database Configuration
MONGODB_URI=mongodb://admin:password123@localhost:27017/sohel_gadgets?authSource=admin

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Application Configuration
NODE_ENV=development
PORT=5000

# Frontend Configuration
VITE_API_BASE=http://localhost:5000

# Docker Configuration (for production)
# MONGODB_URI=mongodb://admin:password123@mongodb:27017/sohel_gadgets?authSource=admin
# JWT_SECRET=change-this-in-production-to-a-secure-random-string
# NODE_ENV=production
